{
  "name": "mpt-extenion-example-ui",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "main": "./static/index.js",
  "types": "./static/index.d.ts",
  "scripts": {
    "build:types": "tsc -p tsconfig.json",
    "build:code": "node esbuild.config.js",
    "build": "npm run build:types && npm run build:code",
    "watch:types": "tsc -p tsconfig.json --watch",
    "watch:code": "node esbuild.config.js --watch",
    "start": "npm-run-all --parallel watch:types watch:code"
  },
  "files": [
    "../static"
  ],
  "dependencies": {
    "@mpt-extension/sdk": "^0.0.5",
    "@mpt-extension/sdk-react": "^0.0.5",
    "@softwareone-platform/rql-client": "^0.1.1",
    "@softwareone-platform/sdk-react-ui-v0": "^0.0.2",
    "axios": "1.15.0",
    "esbuild-sass-plugin": "^3.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.1.1",
    "react-router": "^7.13.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.2",
    "js-yaml": "^4.1.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  }
}
